{% rawHtml html="<style>\n@keyframes vskel-shimmer {\n  0%   { background-position: -600px 0; }\n  100% { background-position: 600px 0; }\n}\n.vskel-wrap {\n  display: flex;\n  gap: 1rem;\n  flex-direction: column;\n  transition: opacity 0.5s;\n}\n.vskel-row {\n  display: flex;\n  gap: 0.5rem;\n}\n.vskel {\n  background: linear-gradient(90deg, #c4c9e6 25%, #eceef9 50%, #c4c9e6 75%);\n  background-size: 1200px 100%;\n  animation: vskel-shimmer 1.4s ease-in-out infinite;\n  border-radius: 8px;\n  height: 2.75rem;\n  flex: 1;\n  width: 100%;\n}\n.vskel-tall {\n  height: 3rem;\n}\n.site .body div.vskel, .site .body div.vskel-row {\n  margin-bottom: 0px;\n}\n</style>\n\n<div id=\"vskel-en\" class=\"vskel-wrap\">\n  <div class=\"vskel-row\">\n    <div class=\"vskel vskel-tall\"></div>\n    <div class=\"vskel vskel-tall\"></div>\n    <div class=\"vskel vskel-tall\"></div>\n    <div class=\"vskel vskel-tall\"></div>\n  </div>\n  <div class=\"vskel-row\">\n    <div class=\"vskel\"></div>\n    <div class=\"vskel\"></div>\n  </div>\n  <div class=\"vskel-row\">\n    <div class=\"vskel\"></div>\n  </div>\n  <div class=\"vskel-row\">\n    <div class=\"vskel\"></div>\n  </div>\n  <div class=\"vskel-row\">\n    <div class=\"vskel\"></div>\n  </div>\n</div>\n\n<script>\n(function(){\n  var el=document.getElementById('vskel-en');\n  var target=document.querySelector('.virtuous-hack');\n  var errorHtml='<p>Form not loading? Visit <a href=\"https://planc.givevirtuous.org/donate\" target=\"_blank\" aria-label=\"(opens in new window)\" class=\"underline cursor-pointer\">planc.givevirtuous.org/donate</a>.</p>';\n  requestAnimationFrame(function(){\n    var obs;\n    var timer=setTimeout(function(){\n      el.innerHTML=errorHtml;\n    },10000);\n    obs=new MutationObserver(function(muts){\n      for(var i=0;i<muts.length;i++){\n        var added=muts[i].addedNodes;\n        for(var j=0;j<added.length;j++){\n          var n=added[j];\n          if(n.nodeType===1&&(n.classList&&n.classList.contains('v_l')||n.querySelector('.v_l'))){\n            clearTimeout(timer);\n            el.style.opacity='0';\n            setTimeout(function(){el.style.display='none';},500);\n            obs.disconnect();return;\n          }\n        }\n      }\n    });\n    obs.observe(target||document.body,{childList:true,subtree:true});\n  });\n})();\n</script>\n\n<div class=\"virtuous-hack\">\n<script \n    src=\"https://cdn.virtuoussoftware.com/virtuous.embed.min.js\" \n    data-vform=\"6C1D0B07-D9E3-4406-90FE-62D2BB06A9E4\" \n    data-orgId=\"7580\" \n    data-isGiving=\"true\"\n    data-merchantType=\"StripeUnified\"\n    data-dependencies=\"[]\">\n</script>\n</div>\n\n<style>\nhtml { line-height: initial; }\na.bg-white-20 { background-color: #fff; }\na.bg-pink-50 { background-color: #fdd5f9; }\na.bg-red-80 { background-color: #ffaeb5; }\na.bg-red-20 { background-color: #fff2f3; }\nbutton { font-family: var(--font-main); line-height: initial; font-size: var(--text-md); }\n\n</style>" _language="en" /%}

{% rawHtml html="<style>\n@keyframes vskel-shimmer {\n  0%   { background-position: -600px 0; }\n  100% { background-position: 600px 0; }\n}\n.vskel-wrap {\n  display: flex;\n  gap: 1rem;\n  flex-direction: column;\n  transition: opacity 0.5s;\n}\n.vskel-row {\n  display: flex;\n  gap: 0.5rem;\n}\n.vskel {\n  background: linear-gradient(90deg, #c4c9e6 25%, #eceef9 50%, #c4c9e6 75%);\n  background-size: 1200px 100%;\n  animation: vskel-shimmer 1.4s ease-in-out infinite;\n  border-radius: 8px;\n  height: 2.75rem;\n  flex: 1;\n  width: 100%;\n}\n.vskel-tall {\n  height: 3rem;\n}\n.site .body div.vskel, .site .body div.vskel-row {\n  margin-bottom: 0px;\n}\n</style>\n\n<div id=\"vskel-es\" class=\"vskel-wrap\">\n  <div class=\"vskel-row\">\n    <div class=\"vskel vskel-tall\"></div>\n    <div class=\"vskel vskel-tall\"></div>\n    <div class=\"vskel vskel-tall\"></div>\n    <div class=\"vskel vskel-tall\"></div>\n  </div>\n  <div class=\"vskel-row\">\n    <div class=\"vskel\"></div>\n    <div class=\"vskel\"></div>\n  </div>\n  <div class=\"vskel-row\">\n    <div class=\"vskel\"></div>\n  </div>\n  <div class=\"vskel-row\">\n    <div class=\"vskel\"></div>\n  </div>\n  <div class=\"vskel-row\">\n    <div class=\"vskel\"></div>\n  </div>\n</div>\n\n<script>\n(function(){\n  var el=document.getElementById('vskel-es');\n  var target=document.querySelector('.virtuous-hack');\n  var errorHtml='<p>¿No carga el formulario? Visite <a href=\"https://planc.givevirtuous.org/donate\" target=\"_blank\" aria-label=\"(opens in new window)\" class=\"underline cursor-pointer\">planc.givevirtuous.org/donate</a>.</p>';\n  requestAnimationFrame(function(){\n    var obs;\n    var timer=setTimeout(function(){\n      el.innerHTML=errorHtml;\n    },10000);\n    obs=new MutationObserver(function(muts){\n      for(var i=0;i<muts.length;i++){\n        var added=muts[i].addedNodes;\n        for(var j=0;j<added.length;j++){\n          var n=added[j];\n          if(n.nodeType===1&&(n.classList&&n.classList.contains('v_l')||n.querySelector('.v_l'))){\n            clearTimeout(timer);\n            el.style.opacity='0';\n            setTimeout(function(){el.style.display='none';},500);\n            obs.disconnect();return;\n          }\n        }\n      }\n    });\n    obs.observe(target||document.body,{childList:true,subtree:true});\n  });\n})();\n</script>\n\n<div class=\"virtuous-hack\">\n<script \n    src=\"https://cdn.virtuoussoftware.com/virtuous.embed.min.js\" \n    data-vform=\"C33F7DE9-5DA1-475E-9559-EC73E10E9C8A\" \n    data-orgId=\"7580\" \n    data-isGiving=\"true\"\n    data-merchantType=\"StripeUnified\"\n    data-dependencies=\"[]\">\n</script>\n</div>\n\n<style>\nhtml { line-height: initial; }\na.bg-white-20 { background-color: #fff; }\na.bg-pink-50 { background-color: #fdd5f9; }\na.bg-red-80 { background-color: #ffaeb5; }\na.bg-red-20 { background-color: #fff2f3; }\nbutton { font-family: var(--font-main); line-height: initial; font-size: var(--text-md); }\n\n</style>" _language="es" /%}
